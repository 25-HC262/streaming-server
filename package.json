{
  "name": "streaming-server",
  "version": "1.0.0",
  "description": "A streaming server with FFmpeg integration",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "ffmpeg": "node src/ffmpeg.js",
    "ffmpeg:invert": "node src/ffmpeg.js --invert",
    "ffmpeg:both": "npm run ffmpeg && npm run ffmpeg:invert"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "express": "^4.18.2",
    "hls-server": "^1.5.0",
    "ws": "^8.18.0"
  },
  "keywords": [
    "streaming",
    "ffmpeg",
    "video"
  ],
  "author": "",
  "license": "ISC"
}
